.priv-storage/
# ===== Security Keys - NEVER COMMIT =====
# ECDSA private keys - multiple layers of protection
*.pem
*.key
*_private*
*private_*
keys/
ecdsa_private_keys.h
ecdsa_private_keys.*
*ecdsa*private*
*ECDSA*PRIVATE*

# Private key patterns (hex array patterns in any file)
# NOTE: Can't gitignore by content, but these filenames catch common cases
*secret*key*
*SECRET*KEY*

# Apple signing & credentials
*.p12
*.p8
*.mobileprovision
*.provisionprofile
*.cer
*.csr

# Certificate working directory
.certs/

# Environment files
.env
.env.*

# Backup files that might contain keys
*.bak
*.backup
*.orig
*.tmp
*~.h
*.h.bak
*.h.backup

# Firmware keys directory & symlink
0_Pico2-Firmware/Divechecker/keys
0_Pico2-Firmware/**/keys/

# Device serial registry (sensitive device inventory)
divechecker_serials.csv

